    "@supabase/supabase-js": "^2.104.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^3.0.4",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^3.0.4",
    "tesseract.js": "^7.0.0",
    "three": "^0.183.2",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
